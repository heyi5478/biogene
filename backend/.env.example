# Backend runtime config — copy to backend/.env and adjust for your machine.

# Which data backend the FastAPI services read from.
#   json     — read mock JSON under backend/mock-data/ (default for dev/CI)
#   postgres — read from the PostgreSQL `gimc` database
GIMC_DATA_BACKEND=json

# PostgreSQL connection used by:
#   - shared.db (async engine, asyncpg driver) — service path
#   - alembic env.py                            — migrations
#   - backend/scripts/seed_from_json.py         — dev seeding
#   - backend/etl/load_pg.py                    — ETL bulk load (uses psycopg)
# Format is SQLAlchemy URL; psycopg variants strip the `+asyncpg` suffix at runtime.
DATABASE_URL=postgresql+asyncpg://gimc:gimc@localhost:5432/gimc

# Filesystem root for binary blobs extracted by 1.0 ETL (MSDATA, GCDATA, MPSUDATA, ENZYME).
# Stored as `raw_data_path` in their corresponding rows.
GIMC_BLOB_ROOT=/srv/gimc/blobs
